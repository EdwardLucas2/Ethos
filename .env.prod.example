# Shared - Production Environment Template
# Copy to .env.prod and fill in the actual values

# Database
DATABASE_URL=jdbc:postgresql://postgres:5432/ethos
DATABASE_USER=ethos
DATABASE_PASSWORD=
DBMATE_URL=postgres://ethos:@postgres:5432/ethos

# Services (use internal service names in docker network)
SUPERTOKENS_URL=http://supertokens:3567
API_URL=http://backend:8080
AUTH_URL=http://auth:3568

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=/app/data/uploads